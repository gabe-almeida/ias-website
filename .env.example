# Copy to .env for local dev. On Render, set these as service env vars.

# Long random string — `openssl rand -hex 32`. Rotating it invalidates sessions.
PAYLOAD_SECRET=replace-with-a-long-random-string

# SQLite (libSQL) connection. Local: a file in the repo. Render: the mounted disk.
#   local  -> file:./blog.db
#   render -> file:/var/data/blog.sqlite
DATABASE_URI=file:./blog.db

# Public base URL — feeds metadataBase, sitemap, robots, llms.txt, JSON-LD.
#   local  -> http://localhost:3000
#   render -> https://iasamerica.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Where uploaded media is written. Local default: ./media. Render: the disk.
#   render -> /var/data/media
MEDIA_DIR=

# First-admin bootstrap (Render). On boot, if Users is empty and these are set,
# an admin is auto-created so the public "create first user" screen never shows.
# Set for the first deploy only; unset + rotate the password in /admin afterward.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# Cloudflare Turnstile (bot protection on the /admin login). Create a widget at
# Cloudflare dashboard → Turnstile. Site key is public; secret key is server-only.
# Leave BOTH blank to disable the login bot-gate (e.g. local dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Lead-form email notifications (the public "Submit a Sample" / contact forms).
# Every submission is ALWAYS captured to the `submissions` collection in /admin;
# RESEND_API_KEY only controls the optional real-time email alert. Leave it blank
# and capture still works (email is skipped). Resend is used because Render blocks
# outbound SMTP — https://resend.com → API Keys.
#   RESEND_API_KEY -> re_xxxxxxxx  (the ONLY email env var — it's a credential)
#
# The recipient + sender addresses are NOT env vars. They live in the
# `notification-settings` global (SQLite, editable at /admin → Leads → Email
# Notifications) so they can be changed with no redeploy. See
# src/globals/NotificationSettings.ts.
RESEND_API_KEY=
